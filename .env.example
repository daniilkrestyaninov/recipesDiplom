# =========================================================================
# AI SERVICE CONFIGURATION TEMPLATE
# =========================================================================

# --- OPTION 1: Sberbank GigaChat Integration (100% Free & Resilient in Russia) ---
# To use Sberbank's free GigaChat:
# 1. Register on SberDevices (developers.sber.ru/portal/products/gigachat-api)
# 2. Go to your dashboard and copy "Авторизационные данные" (Base64 credential string)
# 3. Paste it below and uncomment the variables:

# GIGACHAT_AUTH_DATA="YOUR_SBER_BASE64_CREDENTIALS"
# GIGACHAT_SCOPE="GIGACHAT_API_PERS"   # Use GIGACHAT_API_CORP for business accounts
# GIGACHAT_MODEL="GigaChat"            # Default model name


# --- OPTION 2: OpenAI-Compatible / DeepSeek Fallback ---
# If GIGACHAT_AUTH_DATA is empty, the system will use this standard endpoint.
# DeepSeek does not block Russian IPs and is extremely cheap.
# Or you can point it to a local Ollama server (http://localhost:11434/v1).

# AI_BASE_URL="https://api.deepseek.com"
# AI_API_KEY="YOUR_DEEPSEEK_API_KEY"
# AI_MODEL="deepseek-chat"


# --- OTHER API ENVIRONMENT KEYS ---
# PORT=5000
# DATABASE_URL="postgresql://user:password@localhost:5432/recipes"
